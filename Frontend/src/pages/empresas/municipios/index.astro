---
import { ListadoMunicipio } from "../../../components/ListadoMunicipios";
import GlobalLayout from "../../../layout/GlobalLayout.astro";
import { axiosInstance } from "../../../utils/axiosInstance";

const rol = (Astro.cookies.get("rol") || {})?.value;

if (!rol || rol !== "admin") {
  return Astro.redirect("/");
}
const { data: dataMunicipio } = await axiosInstance("/municipios", {
  method: "GET",
  params: { skip: 0, limit: 100 },
});
---

<GlobalLayout title="Municipios">
  <style>
    .content-form-crear-empresa {
      min-height: calc(100vh - 120px);
      display: flex;
      justify-content: center;
    }

    .content-form-crear-empresa h2 {
      text-align: center;
      margin-block: 60px;
    }
  </style>

  <div class="content-form-crear-empresa">
    <section>
      <h2>Municipios</h2>
      <ListadoMunicipio municipios={dataMunicipio || []} client:load />
    </section>
  </div>
</GlobalLayout>
