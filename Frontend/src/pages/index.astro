---
import GlobalLayout from "../layout/GlobalLayout.astro";
import CardEmpresa from "../components/commons/CardEmpresa"; // 👈 singular
import { axiosInstance } from "../utils/axiosInstance";

let empresas = [];

try {
  const res = await axiosInstance("/empresas", { method: "GET" });
  empresas = res.data;
} catch (error) {
  console.error("Error al cargar empresas:", error);
}

<GlobalLayout title="Directorio de Empresas">
<GlobalLayout title="Directorio">
  <section class="py-12 px-6 bg-gray-50 rounded-xl">
    <h1 class="text-3xl font-extrabold mb-8 text-center text-gray-900">
      Directorio
    </h1>
    <CardEmpresa empresas={empresas} client:load />  
  </section>
</GlobalLayout>
