{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "backend+frontend (FastAPI + Astro)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.api.main:app",
        "--reload",
        "--host", "127.0.0.1",
        "--port", "8000"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "preLaunchTask": "frontend:dev"
    },
    {
      "name": "solo-backend (FastAPI)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "server.api.main:app",
        "--reload"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}